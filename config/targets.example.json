{
  "_comment": "EDR-WD 多目标配置示例",
  "_comment2": "复制为 targets.local.json 并填入真实值，不要提交 targets.local.json 到仓库",

  "default_target": "win-dev",

  "targets": {
    "win-dev": {
      "_comment": "示例：内网目标优先使用账号密码直连；TODO: 后续安全加固可改 password_env 或 key auth",
      "description": "开发环境 Windows 虚拟机（password auth）",

      "platform": "windows",

      "ssh": {
        "host": "<target-ip>",
        "port": 22,
        "user": "<TARGET_USER>",
        "auth": {
          "type": "password",
          "password": "<TARGET_PASSWORD>"
        }
      },

      "mcp": {
        "host": "0.0.0.0",
        "port": 8765,
        "path": "/mcp",
        "connect_mode": "direct",
        "tunnel": {
          "enabled": false,
          "local_port": 18765
        }
      },

      "windows": {
        "python_path": "C:\\Program Files\\Python313\\python.exe",
        "target_root": "C:\\Users\\<TARGET_USER>\\Desktop\\edr-wd\\target",
        "task_name": "StartEDRMCP",
        "run_with_highest_privileges": true
      }
    },

    "mac-dev": {
      "_comment": "示例：macOS target — password auth 默认；lifecycle 走 launchd",
      "description": "macOS 开发机（password auth，LaunchAgent）",

      "platform": "macos",
      "app_profile": "macos_generic",

      "ssh": {
        "host": "<macos-target-ip>",
        "port": 22,
        "user": "<MAC_USER>",
        "auth": {
          "type": "password",
          "password": "<TARGET_PASSWORD>"
        }
      },

      "mcp": {
        "host": "0.0.0.0",
        "port": 8765,
        "path": "/mcp",
        "connect_mode": "direct",
        "tunnel": {
          "enabled": false,
          "local_port": 18765
        }
      },

      "macos": {
        "python_path": "/opt/homebrew/bin/python3",
        "root": "/Users/<MAC_USER>/edr-wd/target",
        "backend": "macos_accessibility",
        "launch_name": "com.edr-wd.target"
      }
    }
  }
}
